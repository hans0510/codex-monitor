{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Token Monitor",
  "version": "0.1.0",
  "identifier": "com.local.codextokenmonitor",
  "build": {
    "frontendDist": "ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Codex Token Monitor",
        "width": 360,
        "height": 680,
        "minWidth": 360,
        "minHeight": 680,
        "maxWidth": 360,
        "maxHeight": 680,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": false,
        "shadow": false,
        "center": false,
        "x": 40,
        "y": 80
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
